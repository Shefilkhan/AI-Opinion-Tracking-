APP_NAME=OpinionPulse
APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=opinionpulse_db

SECRET_KEY=change_this_secret_key_later
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# YouTube Data API v3 (Part 9B) — never expose to frontend
YOUTUBE_API_KEY=your_youtube_data_api_key_here
YOUTUBE_MAX_VIDEOS_PER_KEYWORD=3
YOUTUBE_MAX_COMMENTS_PER_VIDEO=20

# Reddit Data API via PRAW (Part 9C) — never expose to frontend
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=OpinionPulse/1.0 by your_reddit_username
REDDIT_MAX_POSTS_PER_KEYWORD=10
REDDIT_MAX_COMMENTS_PER_POST=10

# Email OTP (registration + login) — required for real inbox delivery
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords)
# Without SMTP, dev mode shows the code on the OTP screen and logs: [OpinionPulse DEV OTP]
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_NAME=OpinionPulse
SMTP_FROM_EMAIL=your_email@gmail.com

OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
