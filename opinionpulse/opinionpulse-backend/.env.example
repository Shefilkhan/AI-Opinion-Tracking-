# Copy to .env.local in this folder — never commit .env.local

APP_NAME=OpinionPulse
APP_ENV=development

# Database
DATABASE_URL=mysql+aiomysql://user:password@localhost/dbname
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=opinionpulse_db

# JWT
SECRET_KEY=generate_a_random_32_char_string_here
JWT_SECRET=generate_a_random_32_char_string_here
OTP_SECRET=generate_another_random_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ACCESS_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
FRONTEND_URL=http://localhost:5173
AUTH_COOKIE_NAME=opinionpulse_token
AUTH_COOKIE_SECURE=false
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Email (Gmail SMTP)
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_NAME=OpinionPulse
SMTP_FROM_EMAIL=your_gmail@gmail.com

OTP_EXPIRE_MINUTES=2
OTP_MAX_ATTEMPTS=3
OTP_RESEND_MAX_PER_WINDOW=3
OTP_RESEND_WINDOW_MINUTES=10

# Reddit (no key needed for public search)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=OpinionPulse/1.0

# NewsAPI — get free key at newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# YouTube — get free key at console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Guardian — get free key at open-platform.theguardian.com
GUARDIAN_API_KEY=your_guardian_api_key_here

# Mediastack — get free key at mediastack.com/signup/free
MEDIASTACK_API_KEY=your_mediastack_api_key_here

# Currents — get free key at currentsapi.services/en/register
CURRENTS_API_KEY=your_currents_api_key_here

# GNews — get free key at gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# Cache
CACHE_DURATION_SECONDS=300

# Groq AI — get free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Anthropic (optional paid alternative)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# AI Provider
AI_PROVIDER=groq
