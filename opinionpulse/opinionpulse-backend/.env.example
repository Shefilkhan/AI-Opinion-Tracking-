# Copy to .env or .env.local in this folder (pydantic reads both; use .env.local for secrets)

# ---------------------------------------------------------------------------
# Email Configuration (Gmail SMTP) — required for real OTP emails
# ---------------------------------------------------------------------------
# EMAIL_USER="youremail@gmail.com"
# EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
#
# Legacy names (still supported): SMTP_USER, SMTP_PASSWORD
# ---------------------------------------------------------------------------

APP_NAME=OpinionPulse
APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=opinionpulse_db

SECRET_KEY=change_this_to_a_random_string_at_least_32_characters_long
OTP_SECRET=change_this_otp_pepper_to_another_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ACCESS_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
FRONTEND_URL=http://localhost:5173
AUTH_COOKIE_NAME=opinionpulse_token
AUTH_COOKIE_SECURE=false
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Gmail SMTP (preferred: EMAIL_USER + EMAIL_APP_PASSWORD above)
EMAIL_USER=
EMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_NAME=OpinionPulse
SMTP_FROM_EMAIL=

OTP_EXPIRE_MINUTES=2
OTP_MAX_ATTEMPTS=3
OTP_RESEND_MAX_PER_WINDOW=3
OTP_RESEND_WINDOW_MINUTES=10

# --- Free search APIs (only these sources are used) ---
# Reddit — public search works with User-Agent only
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=OpinionPulse/1.0

# NewsAPI.org — https://newsapi.org/register
NEWS_API_KEY=

# YouTube Data API v3 — https://console.cloud.google.com
YOUTUBE_API_KEY=

# The Guardian — https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=

# Mediastack — https://mediastack.com/signup/free
MEDIASTACK_API_KEY=

# Currents API — https://currentsapi.services/en/register
CURRENTS_API_KEY=

# GNews — https://gnews.io/
GNEWS_API_KEY=

# No keys needed: Dev.to, Hacker News, Wikipedia

CACHE_DURATION_SECONDS=300

OPENAI_API_KEY=
